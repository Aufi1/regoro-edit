{
  "name": "regoro-edit",
  "version": "0.2.0",
  "description": "Inline-WYSIWYG-Editor für bestehende statische HTML-Websites. Installieren, Passwort setzen, an jede Seite /edit anhängen.",
  "type": "module",
  "bin": {
    "regoro": "src/cli.ts"
  },
  "scripts": {
    "start": "bun src/cli.ts",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "build:binary": "bun build --compile src/cli.ts --outfile dist/regoro"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "dependencies": {
    "linkedom": "^0.18.12"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.14"
  }
}
