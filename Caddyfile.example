# Beispiel-Caddyfile für den regoro-edit Inline-Editor.
#
# Aufgabe des Proxys:
#   - statische Site direkt ausliefern (schnell, billig, der Bun-Prozess ist
#     dafür NICHT im Pfad),
#   - /edit* an den Bun-Editor-Host (localhost:8788) weiterreichen (Auth dort),
#   - TLS automatisch (Let's-Encrypt / ACME) — das Auth-Cookie ist `Secure`,
#     setzt also HTTPS voraus,
#   - .regoro/ und alle Dotfiles HART blocken (404) — die Auth-Datei darf
#     niemals ausgeliefert werden,
#   - nur bekannte Dateitypen ausliefern (Allowlist, siehe unten).
#
# Anpassen: Domain, root-Pfad zur Site, ggf. Port.

example.com {
    encode gzip

    # --- Harte Block-Regel: Auth-Datei + Dotfiles nie ausliefern ---------------
    # Greift VOR allem anderen. Deckt /.regoro/... und beliebige versteckte
    # Dateien/Verzeichnisse (/.git, /.env, ...) ab.
    @hidden path /.regoro/* /.*
    handle @hidden {
        respond 404
    }

    # --- Editor-Routen an den Bun-Host (Auth + Sessions laufen dort) -----------
    @editor path /edit*
    handle @editor {
        reverse_proxy localhost:8788
    }

    # --- Statische Site: NUR erlaubte Dateitypen -------------------------------
    # Positive Allowlist, spiegelt ASSET_TYPES in src/host.ts (+ .html für Seiten).
    # Grund: Ein Site-Ordner enthält oft mehr als die Website — Build-Artefakte
    # (design.json, images.json), Backups (dump.sql), Notizen (README.md). Der
    # Bun-Host liefert die dank Extension-Allowlist nie aus; ein blankes
    # `file_server` hier schon. Ohne diese Regel divergieren die beiden Pfade,
    # und der Proxy wird zum Leck. Kein .svg (script-fähig → Stored-XSS).
    @allowed path / */ *.html *.css *.js *.png *.jpg *.jpeg *.webp *.gif *.ico *.woff *.woff2 *.txt *.xml
    handle @allowed {
        # WICHTIG: derselbe Ordner, den `regoro-edit <dir>` bearbeitet, sonst
        # divergieren öffentliche Seite und Editier-Ziel.
        root * /srv/site
        file_server
    }

    # --- Alles andere: existiert für die Öffentlichkeit nicht ------------------
    handle {
        respond 404
    }
}
